---
interface Props {
  lang?: 'nl' | 'en';
  currentPath?: string;
}

const { lang = 'nl', currentPath = '' } = Astro.props;

const navNL = [
  { href: '/nl/werk/', label: 'Werk' },
  { href: '/nl/fancy-boogers/', label: 'Fancy Boogers' },
  { href: '/nl/borduurwerk/', label: 'Borduurwerk' },
  { href: '/nl/workshops/', label: 'Workshops' },
  { href: '/nl/winkel/', label: 'Winkel' },
  { href: '/nl/over-wievien/', label: 'Over' },
  { href: '/nl/contact/', label: 'Contact' },
];

const navEN = [
  { href: '/en/work/', label: 'Work' },
  { href: '/en/fancy-boogers/', label: 'Fancy Boogers' },
  { href: '/en/embroidery/', label: 'Embroidery' },
  { href: '/en/workshops/', label: 'Workshops' },
  { href: '/en/shop/', label: 'Shop' },
  { href: '/en/about/', label: 'About' },
  { href: '/en/contact/', label: 'Contact' },
];

const nav = lang === 'nl' ? navNL : navEN;
const langSwitchHref = lang === 'nl' ? '/en/work/' : '/nl/werk/';
const langSwitchLabel = lang === 'nl' ? 'EN' : 'NL';
---

<header class="site-header">
  <div class="header-inner">
    <a href={lang === 'nl' ? '/' : '/en/work/'} class="logo">
      <span class="logo-text">Studio Wievien</span>
    </a>

    <nav class="main-nav" aria-label={lang === 'nl' ? 'Hoofdnavigatie' : 'Main navigation'}>
      <ul>
        {nav.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[{ active: currentPath.startsWith(href) }]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={langSwitchHref} class="lang-switch" aria-label={lang === 'nl' ? 'Switch to English' : 'Schakel naar Nederlands'}>
      {langSwitchLabel}
    </a>

    <button class="menu-toggle" aria-label={lang === 'nl' ? 'Menu openen' : 'Open menu'} aria-expanded="false">
      <span class="menu-icon"></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(12% 0.02 280 / 0.7);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid oklch(30% 0.04 280 / 0.3);
    transition: background 0.4s var(--ease-snappy),
                border-color 0.4s var(--ease-snappy),
                box-shadow 0.4s var(--ease-snappy);
  }

  /* Enhance header when page is scrolled — JS-free detection via animation-timeline */
  @supports (animation-timeline: scroll()) {
    .site-header {
      animation: headerSolid linear both;
      animation-timeline: scroll();
      animation-range: 0px 150px;
    }
  }

  @keyframes headerSolid {
    from {
      background: oklch(12% 0.02 280 / 0.4);
      border-bottom-color: transparent;
      box-shadow: none;
    }
    to {
      background: oklch(12% 0.02 280 / 0.92);
      border-bottom-color: oklch(40% 0.06 330 / 0.2);
      box-shadow:
        0 4px 20px oklch(12% 0.02 280 / 0.5),
        0 1px 0 oklch(72% 0.25 330 / 0.08);
    }
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
    white-space: nowrap;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--accent), var(--gold));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    transition: filter 0.3s var(--ease-snappy);
  }

  .logo:hover .logo-text {
    filter: brightness(1.2);
  }

  .main-nav ul {
    display: flex;
    list-style: none;
    gap: 0.15rem;
  }

  .main-nav a {
    display: block;
    padding: 0.4rem 0.7rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-mid);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.25s var(--ease-snappy), background-color 0.25s var(--ease-snappy);
    letter-spacing: 0.01em;
  }

  .main-nav a:hover {
    color: var(--text);
    background-color: var(--bg-elevated);
  }

  .main-nav a.active {
    color: var(--accent);
    font-weight: 600;
    background-color: oklch(72% 0.25 330 / 0.08);
  }

  .lang-switch {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-light);
    padding: 0.3rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.25s var(--ease-snappy);
  }

  .lang-switch:hover {
    color: var(--gold);
    border-color: var(--gold);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .menu-icon {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--text);
    position: relative;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 2px;
    background-color: var(--text);
    left: 0;
  }

  .menu-icon::before { top: -7px; }
  .menu-icon::after { top: 7px; }

  @media (max-width: 768px) {
    .main-nav {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .header-inner {
      padding: 0.75rem 1rem;
    }
  }
</style>
