---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Studio Wievien"
  description="Studio Wievien — borduurwerk, Fancy Boogers kledinglijn, workshops en meer. Handgemaakt met liefde."
  lang="nl"
  currentPath="/"
>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-aurora" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="hero-tagline">Borduurwerk · Kleding · Workshops</p>
      <h1 class="hero-title">
        <span class="gradient-text">Studio</span>
        <span class="hero-title-line2">Wievien</span>
      </h1>
      <p class="hero-sub">Alles met de hand gemaakt — van draad tot streetwear.</p>
      <div class="hero-cta">
        <a href="/nl/werk/" class="btn btn-primary">
          Bekijk het werk
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/nl/winkel/" class="btn btn-ghost">Naar de winkel</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-img-frame">
        <div class="hero-img-glow" aria-hidden="true"></div>
        <div class="hero-placeholder" aria-hidden="true">
          <span>Hero foto</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Diagonal clip transition hero → intro -->
  <div class="clip-transition clip-diagonal" aria-hidden="true">
    <div class="clip-glow-stripe"></div>
  </div>

  <!-- Intro -->
  <section class="section intro">
    <div class="section-inner intro-inner reveal">
      <h2>Over <span class="gradient-text">Wievien</span></h2>
      <p class="intro-text">
        Wievien is maker, borduurster en ontwerper. Vanuit haar studio werkt ze aan handgeborduurde stukken,
        de kledinglijn Fancy Boogers, en geeft ze workshops voor iedereen die zelf wil leren borduren.
      </p>
      <a href="/nl/over-wievien/" class="link-arrow">Meer over Wievien <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- Wave clip transition intro → werk -->
  <div class="clip-transition clip-wave" aria-hidden="true"></div>

  <!-- Featured Work -->
  <section class="section featured">
    <div class="featured-mesh" aria-hidden="true"></div>
    <div class="section-inner">
      <h2 class="reveal">Uitgelicht <span class="gradient-text">werk</span></h2>
      <div class="work-grid">
        {[1, 2, 3, 4, 5, 6].map((i) => (
          <article class="work-card" style={`--i: ${i}`}>
            <div class="work-card-image">
              <div class="placeholder-img" aria-hidden="true">{i}</div>
            </div>
            <h3>Werk titel {i}</h3>
            <p class="work-card-cat">Borduurwerk</p>
          </article>
        ))}
      </div>
      <a href="/nl/werk/" class="link-arrow section-link">Bekijk al het werk <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <!-- Angled clip transition werk → FB -->
  <div class="clip-transition clip-angle-reverse" aria-hidden="true">
    <div class="clip-glow-stripe stripe-teal"></div>
  </div>

  <!-- Fancy Boogers teaser -->
  <section class="section fancy-boogers">
    <div class="section-deco fb-deco" aria-hidden="true"></div>
    <div class="section-deco fb-deco-2" aria-hidden="true"></div>
    <div class="section-inner fb-grid">
      <div class="fb-content reveal">
        <p class="section-label">Kledinglijn</p>
        <h2>Fancy<br/><span class="gradient-text">Boogers</span></h2>
        <p class="prose">
          Waar borduurwerk en streetwear samenkomen.
          Elk stuk is uniek — handgemaakt en gelimiteerd.
        </p>
        <a href="/nl/fancy-boogers/" class="btn btn-primary">
          Bekijk de collectie
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <div class="fb-image reveal">
        <div class="fb-img-frame">
          <div class="placeholder-img wide" aria-hidden="true">Fancy Boogers foto</div>
          <div class="fb-img-border" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Curved clip transition FB → workshops -->
  <div class="clip-transition clip-curve" aria-hidden="true"></div>

  <!-- Workshop teaser -->
  <section class="section workshops">
    <div class="ws-glow" aria-hidden="true"></div>
    <div class="section-inner reveal">
      <div class="ws-header">
        <div>
          <p class="section-label">Leer het zelf</p>
          <h2>Work<span class="gradient-text">shops</span></h2>
        </div>
        <a href="/nl/workshops/" class="btn btn-ghost">Alle workshops <span aria-hidden="true">→</span></a>
      </div>
      <p class="prose ws-desc">
        Leer borduren van Wievien zelf. Kleine groepen, persoonlijke begeleiding,
        alle materialen inbegrepen.
      </p>
      <div class="ws-card glass">
        <div class="ws-card-image">
          <div class="placeholder-img" aria-hidden="true">Workshop foto</div>
        </div>
        <div class="ws-card-info">
          <p class="ws-card-date">Zaterdag 15 april 2026</p>
          <h3>Basisborduurwerk</h3>
          <p class="ws-card-details">Amsterdam · 3 uur · €45 p.p.</p>
          <p class="ws-card-spots">Nog 8 plaatsen beschikbaar</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===========================
     SCROLL PROGRESS BAR
     scroll-driven animation
     =========================== */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 100%;
    z-index: 200;
    background: linear-gradient(90deg, var(--accent), var(--gold), var(--teal));
    transform-origin: left;
    animation: growProgress linear;
    animation-timeline: scroll();
  }

  @keyframes growProgress {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* ===========================
     SCROLL-TRIGGERED REVEALS
     view() timeline animations
     =========================== */
  @supports (animation-timeline: view()) {
    .reveal {
      animation: fadeSlideUp linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 35%;
    }

    /* Staggered work cards — each card reveals based on its own view position */
    .work-card {
      animation: cardReveal linear both;
      animation-timeline: view();
      animation-range: entry 0% entry 30%;
    }
  }

  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(40px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes cardReveal {
    from {
      opacity: 0;
      transform: translateY(50px) scale(0.92) rotate(1deg);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1) rotate(0deg);
      filter: blur(0);
    }
  }

  /* ===========================
     CLIP-PATH SECTION TRANSITIONS
     Diagonal cuts, waves, curves
     =========================== */
  .clip-transition {
    position: relative;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  /* --- Diagonal cut (hero → intro) --- */
  .clip-diagonal {
    height: 120px;
    margin-top: -120px;
    background: var(--bg-card);
    clip-path: polygon(0 100%, 100% 15%, 100% 100%);
    position: relative;
  }

  .clip-glow-stripe {
    position: absolute;
    top: 12%;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent 2%, var(--accent) 20%, var(--gold) 50%, var(--teal) 80%, transparent 98%);
    transform: rotate(-4.5deg);
    transform-origin: right top;
    opacity: 0.9;
    filter: blur(0.5px);
    box-shadow: 0 0 12px var(--accent-glow), 0 0 30px oklch(72% 0.25 330 / 0.2);
  }

  /* --- Wave (intro → werk) — big sculptural wave --- */
  .clip-wave {
    height: 140px;
    margin-top: -50px;
    margin-bottom: -90px;
    background:
      linear-gradient(180deg, var(--bg-card) 0%, oklch(14% 0.025 280) 100%);
    clip-path: polygon(
      0% 45%,
      3% 42%, 6% 38%, 10% 32%, 14% 28%, 18% 26%,
      22% 28%, 26% 35%, 30% 43%, 34% 50%, 38% 52%,
      42% 50%, 46% 44%, 50% 36%, 54% 30%, 58% 28%,
      62% 30%, 66% 38%, 70% 48%, 74% 55%, 78% 56%,
      82% 52%, 86% 44%, 90% 36%, 94% 32%, 98% 34%, 100% 38%,
      100% 100%, 0% 100%
    );
    position: relative;
  }

  .clip-wave::after {
    content: '';
    position: absolute;
    top: 24%;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--teal-glow), var(--accent-glow), var(--gold-glow), var(--teal-glow));
    clip-path: inherit;
    opacity: 0.5;
    filter: blur(4px);
  }

  /* --- Angled reverse (werk → FB) — sharp carnival slash --- */
  .clip-angle-reverse {
    height: 130px;
    margin-top: -130px;
    background: var(--bg-glow);
    clip-path: polygon(0 30%, 100% 100%, 0 100%);
    position: relative;
  }

  .stripe-teal {
    position: absolute;
    top: 25%;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent 2%, var(--teal) 15%, var(--gold) 50%, var(--energy) 85%, transparent 98%);
    transform: rotate(3.8deg);
    transform-origin: left top;
    opacity: 0.85;
    filter: blur(0.5px);
    box-shadow: 0 0 15px var(--teal-glow), 0 0 30px oklch(75% 0.15 175 / 0.2);
  }

  /* --- Curve (FB → workshops) — elliptical scoop --- */
  .clip-curve {
    height: 100px;
    margin-top: -50px;
    margin-bottom: -50px;
    background: var(--bg-card);
    clip-path: ellipse(55% 100% at 50% 100%);
    position: relative;
  }

  .clip-curve::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 10%;
    right: 10%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold-glow), var(--accent-glow), var(--gold-glow), transparent);
    filter: blur(3px);
    opacity: 0.6;
  }

  /* ===========================
     HERO
     =========================== */
  .hero {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem 8rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 4rem;
    align-items: center;
    overflow: hidden;
  }

  .hero-aurora {
    position: absolute;
    inset: -80%;
    background:
      radial-gradient(ellipse at 15% 20%, oklch(55% 0.28 330 / 0.35) 0%, transparent 45%),
      radial-gradient(ellipse at 85% 50%, oklch(60% 0.22 55 / 0.3) 0%, transparent 45%),
      radial-gradient(ellipse at 40% 80%, oklch(55% 0.2 175 / 0.25) 0%, transparent 40%),
      radial-gradient(ellipse at 70% 20%, oklch(60% 0.22 25 / 0.15) 0%, transparent 35%);
    pointer-events: none;
    animation: auroraShift 15s ease-in-out infinite alternate;
  }

  @keyframes auroraShift {
    0% { transform: translate(0, 0) scale(1) rotate(0deg); }
    33% { transform: translate(4%, -3%) scale(1.08) rotate(1deg); }
    66% { transform: translate(-3%, 2%) scale(1.04) rotate(-0.5deg); }
    100% { transform: translate(2%, -1%) scale(1.06) rotate(0.5deg); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-tagline {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .hero-title-line2 {
    display: block;
    color: var(--text);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--text-mid);
    margin-bottom: 2.5rem;
    max-width: 440px;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-visual {
    position: relative;
    z-index: 1;
  }

  .hero-img-frame {
    position: relative;
  }

  .hero-img-glow {
    position: absolute;
    inset: -25px;
    border-radius: 28px;
    background: conic-gradient(from 0deg, var(--accent), var(--gold), var(--teal), var(--energy), var(--accent));
    opacity: 0.35;
    filter: blur(30px);
    animation: heroGlowRotate 8s linear infinite;
  }

  @keyframes heroGlowRotate {
    to { filter: blur(30px) hue-rotate(360deg); }
  }

  .hero-img-frame .hero-placeholder {
    position: relative;
    border: 2px solid transparent;
    background:
      linear-gradient(var(--bg-elevated), var(--bg-elevated)) padding-box,
      conic-gradient(from 45deg, var(--accent), var(--gold), var(--teal), var(--accent)) border-box;
    border-radius: 16px;
  }

  /* ===========================
     BUTTONS
     =========================== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.75rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.3s var(--ease-snappy);
    cursor: pointer;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), oklch(65% 0.22 350));
    color: #fff;
    box-shadow: 0 4px 20px var(--accent-glow);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px oklch(72% 0.25 330 / 0.5);
    color: #fff;
  }

  .btn-arrow {
    transition: transform 0.3s var(--ease-bouncy);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: oklch(78% 0.18 55 / 0.05);
  }

  /* ===========================
     INTRO
     =========================== */
  .intro {
    background-color: var(--bg-card);
    padding-top: 5rem;
  }

  .intro-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .intro-text {
    color: var(--text-mid);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  /* ===========================
     SECTIONS — base
     =========================== */
  .section {
    padding: 5rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section h2 {
    margin-bottom: 1.5rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }

  .section-link {
    display: inline-block;
    margin-top: 2rem;
  }

  .link-arrow {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.25s var(--ease-snappy), gap 0.25s var(--ease-bouncy);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .link-arrow:hover {
    color: var(--gold);
    gap: 0.6rem;
  }

  /* ===========================
     FEATURED WORK
     Mesh bg + staggered card grid
     =========================== */
  .featured {
    background-color: var(--bg);
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  .featured-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 10% 80%, oklch(50% 0.15 330 / 0.1) 0%, transparent 40%),
      radial-gradient(ellipse at 90% 20%, oklch(55% 0.12 55 / 0.08) 0%, transparent 40%),
      radial-gradient(ellipse at 50% 50%, oklch(50% 0.1 175 / 0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .work-card {
    cursor: pointer;
    transition: opacity 0.35s, filter 0.35s, transform 0.35s var(--ease-snappy);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .work-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    border: 1px solid transparent;
    transition: border-color 0.35s var(--ease-snappy), box-shadow 0.35s var(--ease-snappy);
    pointer-events: none;
  }

  .work-card:hover {
    transform: translateY(-6px) scale(1.02);
  }

  .work-card:hover::after {
    border-color: var(--accent);
    box-shadow: 0 0 25px var(--accent-glow), inset 0 0 25px oklch(72% 0.25 330 / 0.06);
  }

  /* "All-But-Me" spotlight */
  .work-grid:has(.work-card:hover) .work-card:not(:hover) {
    opacity: 0.3;
    filter: saturate(0.15) brightness(0.55);
  }

  .work-card h3 {
    margin-top: 0.75rem;
    font-size: 1rem;
    padding: 0 0.25rem;
  }

  .work-card-cat {
    font-size: 0.8125rem;
    color: var(--text-light);
    margin-top: 0.25rem;
    padding: 0 0.25rem;
  }

  /* ===========================
     FANCY BOOGERS
     Diagonal energy, double glow
     =========================== */
  .fancy-boogers {
    background-color: var(--bg-glow);
    padding: 7rem 1.5rem;
  }

  .section-deco {
    position: absolute;
    pointer-events: none;
  }

  .fb-deco {
    top: -100px;
    right: -80px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--teal-glow) 0%, transparent 65%);
    opacity: 0.6;
    filter: blur(50px);
  }

  .fb-deco-2 {
    bottom: -60px;
    left: -40px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--energy-glow) 0%, transparent 65%);
    opacity: 0.4;
    filter: blur(40px);
  }

  .fb-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .fb-content h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    margin-bottom: 1.25rem;
  }

  .fb-content .btn {
    margin-top: 1.5rem;
  }

  /* Fancy Boogers image — rotating gradient border */
  .fb-img-frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
  }

  .fb-img-border {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    border: 2px solid transparent;
    background:
      linear-gradient(var(--bg-glow), var(--bg-glow)) padding-box,
      linear-gradient(135deg, var(--accent), var(--gold), var(--teal)) border-box;
    pointer-events: none;
  }

  /* ===========================
     WORKSHOPS
     Glass card, gold glow
     =========================== */
  .workshops {
    background-color: var(--bg-card);
    padding: 6rem 1.5rem;
  }

  .ws-glow {
    position: absolute;
    bottom: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, var(--gold-glow) 0%, transparent 65%);
    pointer-events: none;
    opacity: 0.35;
  }

  .ws-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 2rem;
  }

  .ws-desc {
    color: var(--text-mid);
    margin-bottom: 2rem;
  }

  .ws-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    overflow: hidden;
    padding: 0;
    transition: transform 0.4s var(--ease-snappy), box-shadow 0.4s var(--ease-snappy);
  }

  .ws-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px oklch(78% 0.18 55 / 0.15);
  }

  .ws-card-image .placeholder-img {
    aspect-ratio: 16/10;
    border-radius: 16px 0 0 16px;
    height: 100%;
  }

  .ws-card-info {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ws-card-date {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .ws-card-info h3 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .ws-card-details {
    font-size: 0.9375rem;
    color: var(--text-mid);
    margin-bottom: 0.75rem;
  }

  .ws-card-spots {
    font-size: 0.8125rem;
    color: var(--teal);
    font-weight: 600;
  }

  /* ===========================
     PLACEHOLDERS
     (replaced with real photos later)
     =========================== */
  .hero-placeholder,
  .placeholder-img {
    background:
      radial-gradient(ellipse at 30% 30%, oklch(25% 0.06 330 / 0.5) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 70%, oklch(25% 0.05 55 / 0.4) 0%, transparent 60%),
      var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-light);
    font-size: 0.875rem;
    font-style: italic;
    border-radius: 12px;
  }

  .hero-placeholder {
    aspect-ratio: 4/3;
    width: 100%;
  }

  .work-card-image .placeholder-img {
    aspect-ratio: 1;
    border-radius: 12px;
    border: 1px solid var(--border);
    transition: border-color 0.35s var(--ease-snappy);
  }

  .work-card:hover .work-card-image .placeholder-img {
    border-color: oklch(72% 0.25 330 / 0.4);
  }

  .placeholder-img.wide {
    aspect-ratio: 16/9;
    width: 100%;
  }

  /* ===========================
     MOBILE
     =========================== */
  @media (max-width: 768px) {
