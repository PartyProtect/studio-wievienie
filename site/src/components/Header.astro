---
interface Props {
  lang?: 'nl' | 'en';
  currentPath?: string;
}

const { lang = 'nl', currentPath = '' } = Astro.props;

const navNL = [
  { href: '/nl/werk/', label: 'Werk' },
  { href: '/nl/fancy-boogers/', label: 'Fancy Boogers' },
  { href: '/nl/borduurwerk/', label: 'Borduurwerk' },
  { href: '/nl/workshops/', label: 'Workshops' },
  { href: '/nl/winkel/', label: 'Winkel' },
  { href: '/nl/over-wievien/', label: 'Over' },
  { href: '/nl/contact/', label: 'Contact' },
];

const navEN = [
  { href: '/en/work/', label: 'Work' },
  { href: '/en/fancy-boogers/', label: 'Fancy Boogers' },
  { href: '/en/embroidery/', label: 'Embroidery' },
  { href: '/en/workshops/', label: 'Workshops' },
  { href: '/en/shop/', label: 'Shop' },
  { href: '/en/about/', label: 'About' },
  { href: '/en/contact/', label: 'Contact' },
];

const nav = lang === 'nl' ? navNL : navEN;
const langSwitchHref = lang === 'nl' ? '/en/work/' : '/nl/werk/';
const langSwitchLabel = lang === 'nl' ? 'EN' : 'NL';
---

<header class="site-header">
  <div class="header-inner">
    <a href={lang === 'nl' ? '/' : '/en/work/'} class="logo">
      Studio Wievien
    </a>

    <nav class="main-nav" aria-label={lang === 'nl' ? 'Hoofdnavigatie' : 'Main navigation'}>
      <ul>
        {nav.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[{ active: currentPath.startsWith(href) }]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href={langSwitchHref} class="lang-switch" aria-label={lang === 'nl' ? 'Switch to English' : 'Schakel naar Nederlands'}>
      {langSwitchLabel}
    </a>

    <button class="menu-toggle" aria-label={lang === 'nl' ? 'Menu openen' : 'Open menu'} aria-expanded="false">
      <span class="menu-icon"></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid transparent;
    transition: border-color 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  }

  /* Scroll-driven: header solidifies as you scroll */
  @supports (animation-timeline: scroll()) {
    .site-header {
      animation: headerSolidify linear both;
      animation-timeline: scroll();
      animation-range: 0px 120px;
    }
  }

  @keyframes headerSolidify {
    from {
      background: color-mix(in srgb, var(--bg) 60%, transparent);
      border-bottom-color: transparent;
      box-shadow: none;
    }
    to {
      background: color-mix(in srgb, var(--bg) 96%, transparent);
      border-bottom-color: var(--border);
      box-shadow: 0 1px 0 var(--border);
    }
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.3s var(--ease-out);
  }

  .logo:hover {
    opacity: 0.6;
    color: var(--text);
  }

  .main-nav ul {
    display: flex;
    list-style: none;
    gap: 0.1rem;
  }

  .main-nav a {
    display: block;
    padding: 0.35rem 0.65rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-mid);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.25s var(--ease-out);
  }

  .main-nav a:hover {
    color: var(--text);
  }

  .main-nav a.active {
    color: var(--text);
    font-weight: 600;
  }

  .lang-switch {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.25s var(--ease-out);
  }

  .lang-switch:hover {
    color: var(--text);
    border-color: var(--text-mid);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .menu-icon {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--text);
    position: relative;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: '';
    position: absolute;
    width: 22px;
    height: 1.5px;
    background-color: var(--text);
    left: 0;
  }

  .menu-icon::before { top: -6px; }
  .menu-icon::after { top: 6px; }

  @media (max-width: 768px) {
    .main-nav {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .header-inner {
      padding: 0.85rem 1rem;
    }
  }
</style>
