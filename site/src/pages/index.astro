---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Studio Wievien"
  description="Studio Wievien — borduurwerk, Fancy Boogers kledinglijn, workshops en meer. Handgemaakt met liefde."
  lang="nl"
  currentPath="/"
>

  <!-- Scroll progress bar -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <!-- Hero — editorial, asymmetric, the work leads -->
  <section class="hero">
    <div class="hero-content">
      <p class="section-label">Borduurwerk &middot; Kleding &middot; Workshops</p>
      <h1>Studio<br/>Wievien</h1>
      <p class="hero-sub">Alles met de hand gemaakt &mdash;<br/>van draad tot streetwear.</p>
      <div class="hero-cta">
        <a href="/nl/werk/" class="btn btn-primary">Bekijk het werk</a>
        <a href="/nl/winkel/" class="btn btn-ghost">Winkel</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-placeholder parallax-img" aria-hidden="true">
        <span>Hero foto</span>
      </div>
    </div>
  </section>

  <!-- Intro — taupe band, editorial contrast against hero cream -->
  <section class="section intro">
    <div class="intro-inner reveal">
      <hr class="divider" />
      <h2>Over Wievien</h2>
      <p class="intro-text">
        Wievien is maker, borduurster en ontwerper. Vanuit haar studio werkt ze aan handgeborduurde stukken,
        de kledinglijn Fancy Boogers, en geeft ze workshops voor iedereen die zelf wil leren borduren.
      </p>
      <a href="/nl/over-wievien/" class="link-subtle">Meer over Wievien</a>
    </div>
  </section>

  <!-- Featured Work — warm cream, editorial grid with stagger -->
  <section class="section featured">
    <div class="section-inner">
      <div class="featured-header reveal">
        <p class="section-label">Geselecteerd werk</p>
        <h2>Uitgelicht</h2>
      </div>
      <div class="work-grid reveal-stagger">
        {[1, 2, 3, 4, 5, 6].map((i) => (
          <article class="work-card reveal">
            <div class="work-card-image">
              <div class="placeholder-img" aria-hidden="true">{i}</div>
            </div>
            <div class="work-card-info">
              <h3>Werk titel {i}</h3>
              <p class="work-card-cat">Borduurwerk</p>
            </div>
          </article>
        ))}
      </div>
      <div class="section-footer reveal">
        <a href="/nl/werk/" class="link-subtle">Bekijk al het werk</a>
      </div>
    </div>
  </section>

  <!-- Fancy Boogers — DARK editorial contrast section -->
  <section class="section fancy-boogers">
    <div class="section-inner fb-grid reveal">
      <div class="fb-image">
        <div class="placeholder-img wide" aria-hidden="true">Fancy Boogers foto</div>
      </div>
      <div class="fb-content">
        <p class="section-label fb-label">Kledinglijn</p>
        <h2>Fancy<br/>Boogers</h2>
        <p class="fb-description">
          Waar borduurwerk en streetwear samenkomen.
          Elk stuk is uniek — handgemaakt en gelimiteerd.
        </p>
        <a href="/nl/fancy-boogers/" class="btn btn-light">Bekijk de collectie</a>
      </div>
    </div>
  </section>

  <!-- Workshops — warm taupe, clean card -->
  <section class="section workshops">
    <div class="section-inner reveal">
      <div class="ws-header">
        <div>
          <p class="section-label">Leer het zelf</p>
          <h2>Workshops</h2>
        </div>
        <a href="/nl/workshops/" class="link-subtle">Alle workshops</a>
      </div>
      <p class="prose ws-desc">
        Leer borduren van Wievien zelf. Kleine groepen, persoonlijke begeleiding,
        alle materialen inbegrepen.
      </p>
      <div class="ws-card">
        <div class="ws-card-image">
          <div class="placeholder-img" aria-hidden="true">Workshop foto</div>
        </div>
        <div class="ws-card-info">
          <p class="ws-card-date">Zaterdag 15 april 2026</p>
          <h3>Basisborduurwerk</h3>
          <p class="ws-card-details">Amsterdam &middot; 3 uur &middot; &euro;45 p.p.</p>
          <p class="ws-card-spots">Nog 8 plaatsen</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===========================
     HERO — cream bg, editorial asymmetry
     =========================== */
  .hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: var(--text-mid);
    line-height: 1.6;
    max-width: 360px;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-visual {
    position: relative;
    overflow: hidden;
  }

  .hero-placeholder {
    aspect-ratio: 3/4;
    width: 100%;
    border-radius: 2px;
  }

  /* ===========================
     BUTTONS — restrained, editorial
     =========================== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.35s var(--ease-out);
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }

  .btn-primary:hover {
    background-color: var(--accent-hover);
    border-color: var(--accent-hover);
    color: var(--bg);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border-dark);
  }

  .btn-ghost:hover {
    border-color: var(--text);
    color: var(--text);
  }

  /* Light button for dark sections */
  .btn-light {
    background: var(--text-on-dark);
    color: var(--bg-contrast);
    border: 1px solid var(--text-on-dark);
  }

  .btn-light:hover {
    background: var(--accent-light);
    border-color: var(--accent-light);
    color: var(--bg-contrast);
  }

  /* ===========================
     LINK — subtle editorial
     =========================== */
  .link-subtle {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-mid);
    text-decoration: none;
    position: relative;
    transition: color 0.3s var(--ease-out);
  }

  .link-subtle::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--text);
    transition: width 0.4s var(--ease-out);
  }

  .link-subtle:hover {
    color: var(--text);
  }

  .link-subtle:hover::after {
    width: 100%;
  }

  /* ===========================
     SECTIONS — each with its own temperature
     =========================== */
  .section {
    padding: var(--space-xl) 1.5rem;
    position: relative;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section h2 {
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .section-footer {
    margin-top: 2.5rem;
    text-align: center;
  }

  /* ===========================
     INTRO — elegant taupe band
     Pops against the cream hero above
     =========================== */
  .intro {
    background-color: var(--bg-taupe);
    text-align: center;
    padding: var(--space-2xl) 1.5rem;
  }

  .intro-inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .intro .divider {
    background-color: var(--border-dark);
  }

  .intro-text {
    color: var(--text-mid);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  /* ===========================
     FEATURED WORK — back to warm cream
     Contrasts with taupe intro above
     =========================== */
  .featured {
    background-color: var(--bg-warm);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .featured-header {
    margin-bottom: 2.5rem;
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .work-card {
    cursor: pointer;
    transition: opacity 0.4s var(--ease-out);
  }

  .work-card-image {
    overflow: hidden;
    border-radius: 2px;
    margin-bottom: 0.75rem;
    position: relative;
  }

  .work-card-image .placeholder-img {
    aspect-ratio: 4/5;
    transition: transform 0.6s var(--ease-out);
  }

  .work-card:hover .work-card-image .placeholder-img {
    transform: scale(1.04);
  }

  /* :has() — All-but-me spotlight with color-mix desaturation */
  .work-grid:has(.work-card:hover) .work-card:not(:hover) {
    opacity: 0.35;
    filter: saturate(0.6);
    transition: opacity 0.5s var(--ease-out), filter 0.5s var(--ease-out);
  }

  .work-card h3 {
    font-size: 1rem;
    font-weight: 500;
    font-family: var(--font-heading);
  }

  .work-card-cat {
    font-size: 0.6875rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
  }

  /* ===========================
     FANCY BOOGERS — DARK editorial contrast
     The dramatic moment. Everything else is light;
     this section inverts to near-black.
     Like a dark spread in a fashion magazine.
     =========================== */
  .fancy-boogers {
    background-color: var(--bg-contrast);
    color: var(--text-on-dark);
    overflow: hidden;
    padding: var(--space-2xl) 1.5rem;
  }

  .fb-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .fb-image {
    position: relative;
    overflow: hidden;
  }

  .fb-image .placeholder-img {
    aspect-ratio: 4/5;
    border-radius: 2px;
    background-color: var(--bg-contrast-mid);
    color: var(--text-on-dark-muted);
  }

  .fb-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fb-label {
    color: var(--accent-light);
  }

  .fb-content h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.95;
    margin-bottom: 0.75rem;
    color: var(--text-on-dark);
  }

  .fb-description {
    color: var(--text-on-dark-mid);
    line-height: 1.7;
    max-width: 400px;
  }

  .fb-content .btn {
    margin-top: 1.5rem;
    align-self: flex-start;
  }

  /* ===========================
     WORKSHOPS — taupe section
     Warm after the dark FB section
     =========================== */
  .workshops {
    background-color: var(--bg-taupe);
    padding: var(--space-2xl) 1.5rem;
  }

  .ws-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 2rem;
  }

  .ws-desc {
    color: var(--text-mid);
    margin-bottom: 2rem;
  }

  .ws-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    overflow: hidden;
    border-radius: 2px;
    background: var(--bg);
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  }

  .ws-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .ws-card-image .placeholder-img {
    aspect-ratio: 16/10;
    border-radius: 0;
    height: 100%;
  }

  .ws-card-info {
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ws-card-date {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  .ws-card-info h3 {
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
  }

  .ws-card-details {
    font-size: 0.9375rem;
    color: var(--text-mid);
    margin-bottom: 0.5rem;
  }

  .ws-card-spots {
    font-size: 0.8125rem;
    color: var(--accent);
    font-weight: 500;
  }

  /* ===========================
     PLACEHOLDERS
     (replaced with real photos later)
     =========================== */
  .placeholder-img {
    background-color: var(--bg-elevated);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-light);
    font-size: 0.8125rem;
    font-style: italic;
    border-radius: 2px;
  }

  /* ===========================
     MOBILE
     =========================== */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 2.5rem 1rem 4rem;
      gap: 2.5rem;
    }

    .hero-visual {
      order: -1;
    }

    .hero h1 {
      font-size: clamp(2.8rem, 12vw, 4rem);
    }

    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .fb-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .section {
      padding: 3.5rem 1rem;
    }

    .intro,
    .fancy-boogers,
    .featured,
    .workshops {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .ws-card {
      grid-template-columns: 1fr;
    }

    .ws-card-image .placeholder-img {
      aspect-ratio: 16/9;
    }

    .ws-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
